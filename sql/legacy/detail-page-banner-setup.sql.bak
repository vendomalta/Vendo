-- 1. Görseli Supabase Storage'a yükleyin
-- 2. Public URL'i alın
-- 3. Aşağıdaki komutu çalıştırın:
/*
UPDATE public.site_settings
SET setting_value = '{
    "image_url": "https://your-supabase-project.supabase.co/storage/v1/object/public/banners/detail-banner.jpg",
    "link_url": "https://kampanya.com",
    "alt_text": "Kampanya Banner"
}'::jsonb
WHERE setting_key = 'detail_page_banner';
*/

-- Banner'ı aktif/pasif yapma
-- Pasif et:
/*
UPDATE public.site_settings
SET is_active = false
WHERE setting_key = 'detail_page_banner';
*/

-- Aktif et:
/*
UPDATE public.site_settings
SET is_active = true
WHERE setting_key = 'detail_page_banner';
*/

-- Banner'ı tamamen sil
/*
DELETE FROM public.site_settings
WHERE setting_key = 'detail_page_banner';
*/

-- Tüm bannerları listele
/*
