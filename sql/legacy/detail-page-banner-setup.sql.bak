-- ============================================================
-- İLAN DETAY SAYFASI BANNER AYARLAMA
-- ============================================================
-- Bu SQL ile ilan detay sayfasına banner ekleyebilirsiniz.
-- Banner admin panelinden de yönetilebilir.
-- 
-- KULLANIM:
-- 1. Bu SQL dosyasını Supabase SQL Editor'de çalıştırın
-- 2. Admin paneline giriş yapın: /admin/login.html
-- 3. "Reklam Yönetimi" menüsüne tıklayın
-- 4. Banner yükleyin ve ayarları yapın
-- ============================================================

-- ============================================================
-- ADIM 1: SUPABASE STORAGE BUCKET OLUŞTUR
-- ============================================================
-- NOT: Bu kısım Supabase UI'dan yapılmalı çünkü SQL ile bucket oluşturma
-- kısıtlıdır. Ancak policy'ler SQL ile ayarlanabilir.
-- 
-- Supabase Dashboard'da:
-- 1. Storage -> Create a new bucket
-- 2. Name: "banners"
-- 3. Public bucket: YES (✓)
-- 4. Create bucket
-- 
-- Alternatif olarak aşağıdaki JavaScript kodu Admin panelinde çalıştırılabilir:
-- 
-- import { supabase } from './supabase.js';
-- await supabase.storage.createBucket('banners', { public: true });
-- 

-- ============================================================
-- ADIM 2: STORAGE POLICIES (Bucket oluşturulduktan sonra)
-- ============================================================

-- Herkes banner'ları okuyabilir (public bucket)
-- Bu policy otomatik oluşur ancak manuel de eklenebilir

-- Sadece adminler banner yükleyebilir
-- NOT: Bu policy'leri Storage ayarlarında manuel eklemelisiniz:
-- 
-- Policy Name: Admins can upload banners
-- Operation: INSERT
-- SQL: 
--   EXISTS (
--     SELECT 1 FROM public.profiles
--     WHERE id = auth.uid() AND is_admin = TRUE
--   )
-- 

-- Sadece adminler banner silebilir
-- Policy Name: Admins can delete banners  
-- Operation: DELETE
-- SQL:
--   EXISTS (
--     SELECT 1 FROM public.profiles
--     WHERE id = auth.uid() AND is_admin = TRUE
--   )

-- ============================================================
-- ADIM 3: site_settings TABLOSU VE BANNER KAYDI
-- ============================================================

-- 1. site_settings tablosu varsa banner ekle
INSERT INTO public.site_settings (setting_key, setting_value, is_active, created_at, updated_at)
VALUES (
    'detail_page_banner',
    '{
        "image_url": "https://placehold.co/1200x135/10b981/ffffff?text=BANNER+ALANI",
        "link_url": "https://verde.com/kampanya",
        "alt_text": "Özel Kampanya"
    }'::jsonb,
    true,
    NOW(),
    NOW()
)
ON CONFLICT (setting_key) 
DO UPDATE SET 
    setting_value = EXCLUDED.setting_value,
    is_active = EXCLUDED.is_active,
    updated_at = NOW();

-- 2. Eğer site_settings tablosu yoksa oluştur
CREATE TABLE IF NOT EXISTS public.site_settings (
    id UUID PRIMARY KEY DEFAULT uuid_generate_v4(),
    setting_key TEXT NOT NULL UNIQUE,
    setting_value JSONB NOT NULL DEFAULT '{}'::jsonb,
    is_active BOOLEAN DEFAULT true,
    created_at TIMESTAMPTZ NOT NULL DEFAULT NOW(),
    updated_at TIMESTAMPTZ NOT NULL DEFAULT NOW()
);

-- Index ekle
CREATE INDEX IF NOT EXISTS site_settings_key_idx ON public.site_settings(setting_key);
CREATE INDEX IF NOT EXISTS site_settings_active_idx ON public.site_settings(is_active) WHERE is_active = TRUE;

-- Trigger
DROP TRIGGER IF EXISTS site_settings_updated_at ON public.site_settings;
CREATE TRIGGER site_settings_updated_at
    BEFORE UPDATE ON public.site_settings
    FOR EACH ROW
    EXECUTE FUNCTION public.handle_updated_at();

COMMENT ON TABLE public.site_settings IS 'Site genelinde kullanılan ayarlar (banner, yapılandırma vb.)';
COMMENT ON COLUMN public.site_settings.setting_key IS 'Ayar anahtarı (detail_page_banner, homepage_banner vb.)';
COMMENT ON COLUMN public.site_settings.setting_value IS 'JSONB formatında ayar değeri';

-- RLS Policy
ALTER TABLE public.site_settings ENABLE ROW LEVEL SECURITY;

-- Mevcut policy'leri sil (eğer varsa)
DROP POLICY IF EXISTS "Anyone can view active settings" ON public.site_settings;
DROP POLICY IF EXISTS "Only admins can manage settings" ON public.site_settings;

-- Herkes aktif ayarları okuyabilir
CREATE POLICY "Anyone can view active settings"
ON public.site_settings FOR SELECT
USING (is_active = true);

-- Sadece adminler düzenleyebilir
CREATE POLICY "Only admins can manage settings"
ON public.site_settings FOR ALL
TO authenticated
USING (
    EXISTS (
        SELECT 1 FROM public.profiles
        WHERE id = auth.uid() AND is_admin = TRUE
    )
);

